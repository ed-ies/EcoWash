<Window x:Class="EcoWash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EcoWash"
        xmlns:vm="clr-namespace:EcoWash.ViewModels"
        xmlns:views="clr-namespace:EcoWash.Views"
        mc:Ignorable="d"
        Title="EcoCharge Manager"
Height="600"
Width="1000"
WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:PanelTiendasViewModel}">
            <views:PanelTiendasView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PrincipalViewModel}">
            <views:PrincipalView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TiendasCrudViewModel}">
            <views:TiendasCrudView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#F0F2F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <!-- Menú Lateral-->
        <Border Grid.Column="0"
        Background="#FF7DB6EF"
        Padding="10">
            <StackPanel>
                <TextBlock Text="EcoWash"
                   Foreground="White"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,30"
                   HorizontalAlignment="Center" />

                <Button Content="Principal"
                Command="{Binding ShowMainCommand}"
                Height="40"
                Margin="0,5"
                Background="Transparent"
                Foreground="White"
                BorderThickness="0"
                HorizontalContentAlignment="Left"
                Padding="10,0" />

                <Button Content="Panel de Tiendas"
                Command="{Binding ShowTiendasCommand}"
                Height="40"
                Margin="0,5"
                Background="Transparent"
                Foreground="White"
                BorderThickness="0"
                HorizontalContentAlignment="Left"
                Padding="10,0" />

                <Button Content="Tiendas CRUD"
                Command="{Binding ShowTiendasCrudCommand}"
                Height="40"
                Margin="0,5"
                Background="Transparent"
                Foreground="White"
                BorderThickness="0"
                HorizontalContentAlignment="Left"
                Padding="10,0" />

            </StackPanel>
        </Border>
        <!-- Contenido Principal-->
        <ContentControl Grid.Column="1"
                Margin="20"
                Content="{Binding CurrentView}">
        </ContentControl>
    </Grid>
</Window>
