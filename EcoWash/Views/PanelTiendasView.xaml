<UserControl x:Class="EcoWash.Views.PanelTiendasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             d:DataContext="{d:DesignInstance Type=viewmodels:PanelTiendasViewModel}"
             xmlns:i="clr-namespace:Microsoft.Xaml.Behaviors;assembly=Microsoft.Xaml.Behaviors"
             xmlns:local="clr-namespace:EcoWash.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CargarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Título -->
        <TextBlock Text="Panel de Tiendas"
               FontSize="26"
               FontWeight="SemiBold"
               Foreground="#374151"
               Margin="0,0,0,20" />

        <!-- Dashboard -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding ListaTiendasVisibles}">

                <!-- Panel tipo dashboard -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True"
                               HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- Template de cada tienda -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="220"
                            Margin="10"
                            Padding="12"
                            CornerRadius="10"
                            Background="White"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">

                            <StackPanel>
                                <TextBlock Text="{Binding Nombre}"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#111827"/>

                                <TextBlock Text="{Binding Direccion}"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       Margin="0,4,0,8"/>

                                <Separator/>

                                <TextBlock Text="Estado"
                                       FontSize="11"
                                       Foreground="#9CA3AF"/>

                                <TextBlock FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Text" Value="Abierta"/>
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Text" Value="Cerrada"/>
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
