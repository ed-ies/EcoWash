<UserControl x:Class="EcoWash.Views.TiendasCrudView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:i="clr-namespace:Microsoft.Xaml.Behaviors;assembly=Microsoft.Xaml.Behaviors"
             xmlns:vr="clr-namespace:EcoWash.ValidationRules"
             xmlns:local="clr-namespace:EcoWash.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>

        <!-- ErrorTemplate -->
        <ControlTemplate x:Key="ValidationErrorTemplate">
            <StackPanel>
                <Border BorderBrush="Red" BorderThickness="1">
                    <!-- Placeholder for the TextBox itself -->
                    <AdornedElementPlaceholder x:Name="AdornedElement"/>
                </Border>
                <Border Background="White" BorderBrush="Red" Padding="4" BorderThickness="1,0,1,1" HorizontalAlignment="Left">
                    <ItemsControl ItemsSource="{Binding}" HorizontalAlignment="Left">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ErrorContent}" Foreground="Red"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ControlTemplate>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

    </UserControl.Resources>

    <!-- Cargamos las Estaciones cuando se carga la Vista -->
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding CargarCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <!-- DISEÑO PRINCIPAL -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TITULO -->
        <TextBlock Text="CRUD de Tiendas"
               FontSize="26"
               FontWeight="SemiBold"
               Foreground="#374151"
               Margin="0,0,0,20" 
               Grid.Row="0"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>


            <!-- Listado Tiendas -->
            <Border Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            Padding="10"
            Margin="0,0,10,0"
            Grid.Column="0">

                <DockPanel>
                    <TextBlock Text="Tiendas" FontSize="18" DockPanel.Dock="Top" Margin="0,0,0,10"/>

                    <Button Content="Nueva Tienda" DockPanel.Dock="Bottom" Margin="0,10,0,0" Command="{Binding NuevaTiendaCommand}"/>

                    <ListBox Name="lbTiendas" ItemsSource="{Binding ListaTiendasVisibles}" SelectedItem="{Binding Selected}" DisplayMemberPath="Nombre" >
                        <!-- Indicamos al Binding, el elemento seleccionado para que se trabaje con el -->
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding SelectedItemChangedCommand}"  CommandParameter="{Binding ElementName=lbTiendas, Path=SelectedItem}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Listado Lavadoras -->
            <Border Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            Padding="10"
            Margin="0,0,10,0"
            Grid.Column="1">

                <DockPanel>
                    <TextBlock Text="Lavadoras" FontSize="18" DockPanel.Dock="Top" Margin="0,0,0,10"/>

                    <Button Content="Nueva Lavadora" DockPanel.Dock="Bottom" Margin="0,10,0,0" Command="{Binding NuevaLavadoraCommand}"/>

                    <ScrollViewer>
                        <ListBox ItemsSource="{Binding Lavadoras}"
                        BorderThickness="0"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#D1D5DB"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,4">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Tipo"/>
                                                <ComboBox Width="120" SelectedIndex="{Binding Tipo, Mode=TwoWay}">
                                                    <ComboBoxItem Content="Lavadora" />
                                                    <ComboBoxItem Content="Secadora" />
                                                </ComboBox>

                                                <CheckBox Content="Máquina Ocupada"
                                                Margin="0,10,0,10"
                                                IsChecked="{Binding IsOccupied, Mode=TwoWay}"/>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                            Content="❌"
                                            Margin="10,0,0,0"
                                            Command="{Binding DataContext.BorrarLavadoraCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </DockPanel>
            </Border>


            <!-- Vista detalle Tienda -->
            <ScrollViewer Grid.Column="2">
                <StackPanel Name="FormPanel" Margin="10">

                    <TextBlock Text="Detalle de la tienda:"
                       FontSize="20"
                       Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding Path=Nombre}"
                       FontSize="15"
                       Margin="0,0,0,10"/>

                    <!-- Nombre -->
                    <TextBlock Text="Nombre"/>
                    <TextBox Validation.ErrorTemplate="{StaticResource ValidationErrorTemplate}">
                        <TextBox.Text>
                            <Binding Path="Nombre" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <vr:StringValidationRule Texto="Nombre"/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <!-- Dirección -->
                    <TextBlock Text="Dirección"/>
                    <TextBox Text="{Binding Path=Direccion, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Potencia -->
                    <TextBlock Text="Potencia Contratada"/>
                    <TextBox Validation.ErrorTemplate="{StaticResource ValidationErrorTemplate}">
                        <TextBox.Text>
                            <Binding Path="Potencia" UpdateSourceTrigger="LostFocus" ConverterCulture="es-ES">
                                <Binding.ValidationRules>
                                    <vr:RangoNumericoValidationRule Min="1" Max="5"/>
                                </Binding.ValidationRules>
                            </Binding>
                        </TextBox.Text>
                    </TextBox>

                    <!-- Activa -->
                    <CheckBox Content="Tienda abierta" Margin="0,10,0,10" IsChecked="{Binding Path=IsActive}"/>

                    <!-- ACCIONES -->
                    <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">

                        <Button Content="Guardar"
                        Width="100"
                        Margin="0,0,10,0"
                        Command="{Binding DataContext.GuardarTiendaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />

                        <Button Content="Eliminar"
                        Width="100"
                        Command="{Binding DataContext.BorrarTiendaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
